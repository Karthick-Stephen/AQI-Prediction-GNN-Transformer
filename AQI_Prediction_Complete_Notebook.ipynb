import pandas as pd

def load_data(filepath):
    data = pd.read_csv(filepath)
    return data

data = load_data('path_to_aqi_data.csv')
```

## 2. Preprocessing

```python
from sklearn.preprocessing import MinMaxScaler

# Assuming 'AQI' is the target column and others are features

def preprocess_data(data):
    scaler = MinMaxScaler()
    scaled_data = scaler.fit_transform(data.drop(['AQI'], axis=1))
    return scaled_data, data['AQI']

X, y = preprocess_data(data)
```

